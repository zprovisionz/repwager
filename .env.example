# RepWager — environment template (safe to commit)
#
# Copy this file to `.env.local` in the same folder (project root), then paste
# your real values from Supabase:
#   Dashboard → Project Settings → API
#     - Project URL  → EXPO_PUBLIC_SUPABASE_URL
#     - anon public  → EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# Restart Metro after changes:  npx expo start --clear
#
# Do NOT put the service_role key here — it must never ship in the app bundle.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
