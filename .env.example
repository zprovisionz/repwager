# ============================================================
# Supabase Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Where to find these values:
#   1. Go to https://supabase.com/dashboard
#   2. Open your project
#   3. Click "Settings" in the left sidebar
#   4. Click "API"
#   5. Copy "Project URL" → EXPO_PUBLIC_SUPABASE_URL
#   6. Copy "anon public" key → EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# IMPORTANT:
#   - Never share or commit the .env file (it is already in .gitignore)
#   - After editing .env, restart Expo with:  npx expo start --clear
# ============================================================

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
