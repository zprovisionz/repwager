{
  "expo": {
    "name": "RepWager",
    "slug": "repwager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "repwager",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.repwager.app",
      "infoPlist": {
        "NSCameraUsageDescription": "RepWager needs camera access to count your reps during matches.",
        "NSMicrophoneUsageDescription": "RepWager needs microphone access to record your workout videos."
      }
    },
    "android": {
      "package": "com.repwager.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "repwager" },
            { "scheme": "https", "host": "repwager.app", "pathPrefix": "/challenge" },
            { "scheme": "https", "host": "repwager.app", "pathPrefix": "/profile" },
            { "scheme": "https", "host": "repwager.app", "pathPrefix": "/league" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-camera",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00D4FF",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
