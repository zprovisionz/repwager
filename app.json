{
  "expo": {
    "name": "RepWager",
    "slug": "repwager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "repwager",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "RepWager needs camera access to count your reps during matches.",
        "NSMicrophoneUsageDescription": "RepWager needs microphone access to record your workout videos."
      }
    },
    "android": {
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-camera",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
